# ══════════════════════════════════════════════════════════════════
# KUMPLY Monorepo — .gitignore
# ══════════════════════════════════════════════════════════════════

# ── Dependencies ────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Environment / Secrets ───────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Build outputs ───────────────────────────────────────────────
dist/
.next/
out/
build/

# ── Hardhat / Solidity ──────────────────────────────────────────
contracts/artifacts/
contracts/cache/
contracts/typechain-types/
coverage/
coverage.json

# ── IDE / OS ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-error.log*
.vercel
.turbo

.vercel
CLAUDE.md
claude.md
Memory.md

# ── Internal / not for public repo ──────────────────────────────
LEGAL_REVIEW_BRIEF.md
LEGAL_*.md
INTERNAL_*.md
docs/internal/
claude_estrategico.md

# ── Utility / debug scripts (one-off tooling) ──────────────────
replace.py
update_docs.py
*_keys.txt
*_paths.txt
missing_in_*.txt
.env*
