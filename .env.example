# ──────────────────────────────────────────────────────────────────
# KUMPLY — Environment Variables Template
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# ── Avalanche / Blockchain ────────────────────────────────────────
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
DEPLOYER_PRIVATE_KEY=
# Deployer address is derived automatically from DEPLOYER_PRIVATE_KEY.
# Only set this if you want to override (e.g. for scripts that don't have the key).
DEPLOYER_ADDRESS=

CONTRACT_ATTESTATION_STORE=0x9Bbb0797EA92277c268fe7E45BdB16b70E787d76
CONTRACT_COMPLIANCE_GATE=0x3Bf8F8ea2573Eb3f386aDF72D191869c4827062B

# ── Frontend (public — safe to expose in browser bundle) ──────────
NEXT_PUBLIC_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CHAIN_ID=43113
NEXT_PUBLIC_CONTRACT_ATTESTATION_STORE=0x9Bbb0797EA92277c268fe7E45BdB16b70E787d76
NEXT_PUBLIC_CONTRACT_COMPLIANCE_GATE=0x3Bf8F8ea2573Eb3f386aDF72D191869c4827062B
# Verifier = deployer address (public — shown on /network page)
NEXT_PUBLIC_VERIFIER_ADDRESS=0xD65042534CE80fcb641fd6Eb99a16eBF6C0cd076
# WalletConnect project ID (optional — only needed for WalletConnect connector)
NEXT_PUBLIC_WC_PROJECT_ID=

# ── Sumsub KYC Provider ───────────────────────────────────────────
# Setup: https://cockpit.sumsub.com → App Tokens → create token
# Required verification levels: basic-kyc, standard-kyc, enhanced-kyc, business-kyb, agent-kya
# Webhook URL: https://your-domain.xyz/api/webhook (or /webhook/sumsub for Express API)
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
# SUMSUB_WEBHOOK_SECRET should be the webhook secret from the Sumsub dashboard.
# If not set separately, SUMSUB_SECRET_KEY is used as fallback.
SUMSUB_WEBHOOK_SECRET=
SUMSUB_BASE_URL=https://api.sumsub.com

# ── API (Express backend — apps/api) ─────────────────────────────
API_PORT=3001
API_KEY=kumply-dev-key-change-me
# Comma-separated list of allowed CORS origins
# Example: CORS_ORIGIN=https://kumply.xyz,https://www.kumply.xyz
CORS_ORIGIN=http://localhost:3000

# ── Contract Verification (Snowtrace / Routescan) ─────────────────
# Get your key at https://routescan.io or use "verifyContract" for public endpoint
SNOWTRACE_API_KEY=verifyContract

# ── Environment ───────────────────────────────────────────────────
NODE_ENV=development
